# SAP HANA Database Configuration (for SAP B1 Test Database)
# Uncomment and fill these when connecting to HANA

# HANA_HOST=192.168.1.100
# HANA_PORT=30015
# HANA_DATABASE=SB1_TEST
# HANA_USERNAME=B1_USER
# HANA_PASSWORD=YourPassword123
# HANA_SCHEMA=LIVE_DSL
# HANA_DRIVER=odbc
# HANA_ENCRYPT=yes
# HANA_TRUST_CERT=false
# HANA_TIMEOUT=30
